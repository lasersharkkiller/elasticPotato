{"id": "regph4nt-0001-4ccc-a001-000000000001", "rule_id": "regph4nt-0001-4ccc-a001-000000000001", "name": "[RegPhantom] Kernel Rootkit Driver Load - Known Filenames", "description": "Detects loading of kernel drivers with filenames associated with the RegPhantom rootkit family. RegPhantom is a China-nexus kernel rootkit that abuses CmRegisterCallback to intercept registry writes as a covert usermode-to-kernel C2 channel, then reflectively loads arbitrary PEs into kernel memory invisible to PsLoadedModuleList. Known filenames include MapDriver.sys, TestDriver.sys, MyDriver.sys, FsFilter.sys, DevDriver.sys. Active development observed June-August 2025. Reference: Nextron Systems, March 2026.", "enabled": false, "type": "query", "language": "kuery", "query": "event.action: \"driver_load\" AND file.name: (\"MapDriver.sys\" OR \"TestDriver.sys\" OR \"MyDriver.sys\" OR \"MyDriver-signed-20250619.sys\" OR \"MyDriver_0629.sys\" OR \"0629.sys\" OR \"0627.sys\" OR \"FsFilter.sys\" OR \"DevDriver.sys\")", "index": ["logs-*", "winlogbeat-*", "filebeat-*", "endgame-*"], "risk_score": 99, "severity": "critical", "tags": ["Loaded Potato", "RegPhantom", "China-nexus", "kernel-rootkit", "attack.persistence", "attack.defense-evasion", "attack.privilege-escalation", "attack.t1014", "attack.t1543.003"], "author": ["Loaded Potato"], "references": ["https://www.nextron-systems.com/2026/03/20/regphantom-backdoor-threat-analysis/", "https://attack.mitre.org/techniques/T1014/"], "from": "now-24h", "interval": "5m", "max_signals": 100, "version": 1, "threat": [{"framework": "MITRE ATT&CK", "tactic": {"id": "TA0005", "name": "Defense Evasion", "reference": "https://attack.mitre.org/tactics/TA0005/"}, "technique": [{"id": "T1014", "name": "Rootkit", "reference": "https://attack.mitre.org/techniques/T1014/"}]}, {"framework": "MITRE ATT&CK", "tactic": {"id": "TA0003", "name": "Persistence", "reference": "https://attack.mitre.org/tactics/TA0003/"}, "technique": [{"id": "T1543", "name": "Create or Modify System Process", "reference": "https://attack.mitre.org/techniques/T1543/", "subtechnique": [{"id": "T1543.003", "name": "Windows Service", "reference": "https://attack.mitre.org/techniques/T1543/003/"}]}]}]}
{"id": "regph4nt-0002-4ccc-a002-000000000002", "rule_id": "regph4nt-0002-4ccc-a002-000000000002", "name": "[RegPhantom] Suspicious Code-Signing Certificate - Autel or Xuanfeng", "description": "Detects drivers signed with code-signing certificates abused by the RegPhantom rootkit: Autel Intelligent Technology Corp., Ltd. and Guangzhou Xuanfeng Technology Co., Ltd. These valid Chinese certificates were used to bypass Windows Driver Signature Enforcement (DSE) and load the rootkit as a trusted kernel component.", "enabled": false, "type": "query", "language": "kuery", "query": "event.action: \"driver_load\" AND (file.code_signature.subject_name: (*Autel Intelligent Technology* OR *Guangzhou Xuanfeng Technology*))", "index": ["logs-*", "winlogbeat-*", "filebeat-*", "endgame-*"], "risk_score": 73, "severity": "high", "tags": ["Loaded Potato", "RegPhantom", "China-nexus", "attack.defense-evasion", "attack.t1553.002", "code-signing-abuse"], "author": ["Loaded Potato"], "references": ["https://www.nextron-systems.com/2026/03/20/regphantom-backdoor-threat-analysis/", "https://attack.mitre.org/techniques/T1553/002/"], "from": "now-24h", "interval": "5m", "max_signals": 100, "version": 1, "threat": [{"framework": "MITRE ATT&CK", "tactic": {"id": "TA0005", "name": "Defense Evasion", "reference": "https://attack.mitre.org/tactics/TA0005/"}, "technique": [{"id": "T1553", "name": "Subvert Trust Controls", "reference": "https://attack.mitre.org/techniques/T1553/", "subtechnique": [{"id": "T1553.002", "name": "Code Signing", "reference": "https://attack.mitre.org/techniques/T1553/002/"}]}]}]}
{"id": "regph4nt-0003-4ccc-a003-000000000003", "rule_id": "regph4nt-0003-4ccc-a003-000000000003", "name": "[RegPhantom] Registry Write Access Denied to REG_BINARY - Potential Covert C2 Channel", "description": "Detects registry write operations that fail with access denied (STATUS_ACCESS_DENIED / 0xC0000022), which may indicate the RegPhantom rootkit intercepting and consuming command payloads via CmRegisterCallback. RegPhantom blocks the triggering registry write after processing the 56-byte XOR-encrypted command, so monitoring tools only see a failed RegSetValueEx. This rule looks for patterns of REG_BINARY write failures that are abnormal for the writing process.", "enabled": false, "type": "query", "language": "kuery", "query": "event.action: \"registry_set\" AND event.outcome: \"failure\" AND registry.data.type: \"REG_BINARY\" AND NOT process.name: (\"svchost.exe\" OR \"services.exe\" OR \"lsass.exe\" OR \"TiWorker.exe\" OR \"TrustedInstaller.exe\")", "index": ["logs-*", "winlogbeat-*", "filebeat-*", "endgame-*"], "risk_score": 47, "severity": "medium", "tags": ["Loaded Potato", "RegPhantom", "China-nexus", "attack.command-and-control", "attack.defense-evasion", "attack.t1112", "registry-c2"], "author": ["Loaded Potato"], "references": ["https://www.nextron-systems.com/2026/03/20/regphantom-backdoor-threat-analysis/", "https://attack.mitre.org/techniques/T1112/"], "from": "now-24h", "interval": "5m", "max_signals": 100, "version": 1, "threat": [{"framework": "MITRE ATT&CK", "tactic": {"id": "TA0005", "name": "Defense Evasion", "reference": "https://attack.mitre.org/tactics/TA0005/"}, "technique": [{"id": "T1112", "name": "Modify Registry", "reference": "https://attack.mitre.org/techniques/T1112/"}]}, {"framework": "MITRE ATT&CK", "tactic": {"id": "TA0011", "name": "Command and Control", "reference": "https://attack.mitre.org/tactics/TA0011/"}, "technique": [{"id": "T1071", "name": "Application Layer Protocol", "reference": "https://attack.mitre.org/techniques/T1071/"}]}]}
