 \"6e1254e478d5b7e60a7a6c6c23943884eca59b214d5a8ecdbdea1a0bbd08df58\" OR \"aaed39996db0c5f9b7ebbda773e67aced72100af701bf2cd933c3aae6b31f9ce\" OR \"2ece92c1b221338b0f37cc033b2a160bb03cd4d3c228f0924fcb7be6c9bbea10\" OR \"f25784a7577f2e4fa254e93458f6c92de66c623a3029c284a39f4076bb8d7046\" OR \"39eabd51174ae57bcaa05fc50ff7bb704464b97e315f6e03a6a447000463b261\" OR \"836259c4475e372277b5115f8f4542c4210fd2817aaacd00f0a350b067fde165\" OR \"8f24be8d38df0d2cec0abf78873b83d2a633b650324e99505993604909a13805\" OR \"f06dacf7f7152c632ed435ab60bb1a8e9e9a7eb5d416eb6419eb4446f7fa821f\" OR \"1f3d90ed62bf1b4fd501cbd435d2519486b60ad91704b6e38b93da00960cd22d\" OR \"cc123e35363aeace09900bf3de76080eb46f7e04edede742dbdf2d80be129cc0\" OR \"a0eee7cd05ca3dbddb57414df99768c05ade18f9c13fb31e686558e636badf26\" OR \"9721430672e361eff1f92dd4cc81686635730bc9656f1542411ed2df93dea831\")", "index": ["logs-*", "winlogbeat-*", "filebeat-*", "endgame-*"], "risk_score": 99, "severity": "critical", "tags": ["Loaded Potato", "RegPhantom", "China-nexus", "kernel-rootkit", "hash-match", "attack.defense-evasion", "attack.t1014"], "author": ["Loaded Potato"], "references": ["https://www.nextron-systems.com/2026/03/20/regphantom-backdoor-threat-analysis/"], "from": "now-24h", "interval": "5m", "max_signals": 100, "version": 1, "threat": [{"framework": "MITRE ATT&CK", "tactic": {"id": "TA0005", "name": "Defense Evasion", "reference": "https://attack.mitre.org/tactics/TA0005/"}, "technique": [{"id": "T1014", "name": "Rootkit", "reference": "https://attack.mitre.org/techniques/T1014/"}]}]}
