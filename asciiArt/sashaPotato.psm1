==-===++**##*+=+=====+@@@@@@@@@@@#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@%%%%%@@%%%%#@#@@@@@@@@@@@@@@@%#**++++++##+**#@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
+%%##*===+===---==+==+*@@@@@@@@@@*@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@%@%%%%%@@@%@%@%@%@@@@@@@@@@@@@@@@@@@@@@@%#@%@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
+=+-=====++++=++==+=====@@@@@@@#=++=+%@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@%%#@%#@@#@@@%%@%%@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@
'@
    # Character density -> color map (darkest chars = darkest colors)
    # Mid-density chars (@*+=) in the potato zone shift toward Yellow
    # Adjust $potatoR0/$potatoR1/$potatoC0/$potatoC1 to fine-tune the potato region
    # Potato region  -  three zones for the irregular left edge
    $potatoR0     = 33   # first row
    $potatoR1     = 72   # last  row
    $potatoC0top  = 33   # left edge rows $potatoR0..$potatoSplitTop  (fingers above potato)
    $potatoC0mid  = 20   # left edge rows $potatoSplitTop+1..$potatoSplitLow (potato bulges left)
    $potatoC0low  = 18   # left edge rows $potatoSplitLow+1..$potatoR1
    $potatoSplitTop = 41 # row where potato starts extending further left
    $potatoSplitLow = 61 # row where left boundary shifts right again
    $potatoC1     = 83   # right edge (all rows)

    $lines = $SashaArt -split '\r?\n'

    if ($ShowGuide) {
        Write-Host ("     " + ("0         " * 15)) -ForegroundColor DarkGray
        Write-Host ("     " + ("0123456789" * 15)) -ForegroundColor DarkGray
    }

    foreach ($idx in 0..($lines.Count - 1)) {
        $line = $lines[$idx]
        if ([string]::IsNullOrEmpty($line)) { Write-Host ''; continue }

        if ($ShowGuide) { Write-Host ("{0,3}: " -f $idx) -NoNewline -ForegroundColor DarkGray }

        $buf   = [System.Text.StringBuilder]::new()
        $cur   = $null

        for ($c = 0; $c -lt $line.Length; $c++) {
            $ch = $line[$c]
            $leftBound = if    ($idx -le $potatoSplitTop) { $potatoC0top }
                         elseif ($idx -le $potatoSplitLow) { $potatoC0mid }
                         else                              { $potatoC0low }
            $inPotato  = ($idx -ge $potatoR0 -and $idx -le $potatoR1 -and $c -ge $leftBound -and $c -le $potatoC1)

            $color = switch ($ch) {
                '@' { 'Blue'     }
                '%' { 'DarkCyan' }
                '#' { if ($inPotato) { 'DarkYellow' } else { 'Cyan'     } }
                '*' { if ($inPotato) { 'Yellow'     } else { 'DarkCyan' } }
                '+' { if ($inPotato) { 'Yellow'     } else { 'DarkGray' } }
                '=' { if ($inPotato) { 'DarkYellow' } else { 'DarkGray' } }
                '-' { if ($inPotato) { 'DarkYellow' } else { 'DarkGray' } }
                ':' { if ($inPotato) { 'DarkYellow' } else { 'DarkGray' } }
                '.' { if ($inPotato) { 'Yellow'     } else { 'Gray'     } }
                default { if ($inPotato) { 'DarkYellow' } else { 'DarkGray' } }
            }

            if ($color -eq $cur) {
                [void]$buf.Append($ch)
            } else {
                if ($cur) { Write-Host $buf.ToString() -ForegroundColor $cur -NoNewline }
                $buf = [System.Text.StringBuilder]::new()
                [void]$buf.Append($ch)
                $cur = $color
            }
        }
        if ($buf.Length -gt 0) { Write-Host $buf.ToString() -ForegroundColor $cur -NoNewline }
        Write-Host ''
    }
}